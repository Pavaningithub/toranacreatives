# ─────────────────────────────────────────────────────────────
#  TORANA CREATIVES — Environment Variables Template
#  Copy this file to .env and fill in real values.
#  .env is gitignored — never commit real credentials.
#  Set all vars in: Vercel → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Contact (Required) ───────────────────────────────────────
# WhatsApp Business number with country code (no + or spaces)
VITE_WA=91XXXXXXXXXX
# Business email address
VITE_EMAIL=your@email.com

# ── Social Media ─────────────────────────────────────────────
# Instagram handle without @
VITE_IG_HANDLE=torana_creatives
# Facebook page name/ID (leave empty if not set up yet)
VITE_FB_PAGE=
# Set to "true" once Facebook page is live
VITE_FB_ENABLED=false

# ── Instagram Live Feed (Behold.so) ──────────────────────────
# 1. Sign up free at https://behold.so
# 2. Connect @torana_creatives Instagram Business account
# 3. Create a feed widget → copy the Feed ID (looks like ABC12345)
# 4. Paste it below — your actual posts will appear on the website
VITE_BEHOLD_FEED_ID=

# ── Stats Strip ──────────────────────────────────────────────
# Set VITE_STATS_ENABLED=true to show the stats bar in Hero & About
VITE_STATS_ENABLED=false
VITE_EVENTS_COUNT=5
VITE_YEARS_COUNT=1
VITE_RITUALS_COUNT=15
VITE_FAMILIES_COUNT=5

# ── Supabase (Reviews Database) ──────────────────────────────
# 1. Create a free project at https://supabase.com
# 2. Run the SQL schema from docs/supabase-schema.sql in the SQL editor
# 3. Copy Project URL and anon key from Settings → API
# The anon key is safe to expose publicly (protected by Row Level Security)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Google Drive Photo Sync ───────────────────────────────────
# For auto-syncing photos from Google Drive to the gallery:
# 1. Create a Google Cloud project → enable Google Drive API
# 2. Create a Service Account → download JSON key
# 3. Share your Drive gallery folder with the service account email
# 4. Name photos with project ID prefix: TC_1_wedding_photo.jpg
# 5. Set the vars below and run: npm run gallery:drive
#
# GOOGLE_DRIVE_FOLDER_ID is the long ID from the Drive folder URL
# e.g. https://drive.google.com/drive/folders/1AbCdEfGhIjKlMnOpQrStUvWxYz
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here
# Paste the entire service account JSON as a single-line string
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
